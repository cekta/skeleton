{
  "name": "cekta/skeleton",
  "type": "project",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "cekta/framework": "@dev",
    "ext-pdo": "*",
    "ext-pcntl": "*",
    "cekta/roadrunner": "dev-master",
    "cekta/cli-symfony": "dev-master"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^4.0",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "App\\Runtime\\": "runtime/"
    }
  },
  "scripts": {
    "build": [
      "@putenv CEKTA_MODE=build",
      "@composer dumpautoload",
      "@php app.php",
      "echo Generated optimized Container and discover files"
    ],
    "test": [
      "@php -i",
      "@build",
      "@phpcs",
      "@phpstan"
    ],
    "worker": [
      "@putenv CEKTA_MODE=worker",
      "@php app.php"
    ],
    "phpcs": "./vendor/bin/phpcs",
    "migrate": "@php app.php migrate -i",
    "rollback": "@php app.php rollback",
    "phpstan": "./vendor/bin/phpstan analyse --memory-limit=-1"
  },
  "config": {
    "optimize-autoloader": true
  }
}
